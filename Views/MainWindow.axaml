<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:DIPLOMKA.ViewModels"
        xmlns:model="using:DIPLOMKA.Models"
        xmlns:global="clr-namespace:"
        x:Class="DIPLOMKA.Views.MainWindow"
        x:DataType="global:MainWindowViewModel">
    
    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <StackPanel Margin="20">
        <TextBox Text="{Binding InputText}" 
                 Watermark="Введите текст резюме..."
                 AcceptsReturn="True" 
                 Height="150" />
                
        <Button Content="Анализировать" 
                Command="{Binding Analyze}" 
                Margin="0,10" />
        
        <ListBox ItemsSource="{Binding Employees}" 
                 Width="500">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="global:EmployeeData">
                    <StackPanel Margin="5">
                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="Bold" />
                        <TextBlock Text="{Binding CommunicationStyle}" />
                        <TextBlock Text="{Binding PersonalityType}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <!-- Добавляем кнопку загрузки файлов и TextBlock для информации -->
        <StackPanel Margin="20" Spacing="10">
            <Button Content="Загрузить файлы (.txt)" Command="{Binding LoadFilesCommand}"/>
            <TextBlock Text="{Binding LoadedFilesCount}" Foreground="Gray"/>
    
            <TextBox Text="{Binding InputText}" Watermark="Или введите текст вручную..."
                     AcceptsReturn="True" Height="150"/>
        </StackPanel>
        <ComboBox SelectedIndex="{Binding TeamSizeIndex}" 
                  HorizontalAlignment="Left"
                  Width="100">
            <ComboBoxItem>2 человека</ComboBoxItem>
            <ComboBoxItem>4 человека</ComboBoxItem>
            <ComboBoxItem>6 человека</ComboBoxItem>
            <ComboBoxItem>8 человека</ComboBoxItem>
        </ComboBox>
        <!-- График совместимости -->
        <ProgressBar Value="{Binding AnalysisResult.CompatibilityScore}" 
                     Maximum="100"
                     Height="20"
                     Margin="0,20">
            <ProgressBar.Foreground>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Red" Offset="0"/>
                    <GradientStop Color="Yellow" Offset="0.5"/>
                    <GradientStop Color="Green" Offset="1"/>
                </LinearGradientBrush>
            </ProgressBar.Foreground>
        </ProgressBar>

        <!-- Плюсы/минусы -->
        <ItemsControl ItemsSource="{Binding AnalysisResult.Strengths}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="Green"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <ItemsControl ItemsSource="{Binding AnalysisResult.Weaknesses}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" Foreground="Red"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
    
</Window>
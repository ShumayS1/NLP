<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DIPLOMKA.Views"
        xmlns:viewModels="clr-namespace:DIPLOMKA.ViewModels"
        x:Class="DIPLOMKA.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel" 
        Title="Анализ Портфолио"
        Width="800" Height="600">

    <Window.DataContext>
        <viewModels:MainWindowViewModel />
    </Window.DataContext>

    <Grid>
        <!-- Заголовок -->
        <TextBlock Text="Анализ Портфолио и Мыслей о Задании"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   FontSize="24" FontWeight="Bold"
                   Margin="10" />

        <!-- Панель для загрузки файлов -->
        <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Top">
            <!-- Кнопка загрузки портфолио с обработчиком события -->
            <Button Name="btnUploadPortfolio" Content="Загрузить Портфолио" HorizontalAlignment="Center" Width="200" Margin="10" Click="OnUploadPortfolioClick" />
            <!-- Кнопка загрузки мыслей о задании с обработчиком события -->
            <Button Name="btnUploadTaskThoughts" Content="Загрузить Мысли о Задании" HorizontalAlignment="Center" Width="200" Margin="10" Click="OnUploadTaskThoughtsClick" />
        </StackPanel>

        <!-- Панель для отображения выбранных файлов -->
        <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Center">
            <!-- Привязка к свойствам из ViewModel -->
            <TextBlock Text="{Binding PortfolioFileInfo}" HorizontalAlignment="Center" VerticalAlignment="Top" />
            <TextBlock Text="{Binding TaskThoughtsFileInfo}" HorizontalAlignment="Center" VerticalAlignment="Top" />
        </StackPanel>

        <!-- Панель для анализа данных -->
        <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Bottom">
            <!-- Кнопка анализа с обработчиком события -->
            <Button Name="btnAnalyze" Content="Проанализировать" HorizontalAlignment="Center" Width="200" Margin="10" Click="OnAnalyzeClick" />
            <!-- Привязка к свойству из ViewModel для отображения результата анализа -->
            <TextBlock Text="{Binding AnalysisResult}" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="14" Margin="10"/>
        </StackPanel>
    </Grid>
</Window>
